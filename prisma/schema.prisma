// ============================================================================
// Prisma Configuration
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum DisplayMode {
  YOUTUBE
  CAROUSEL
  CPR
}

enum UserRole {
  ADMIN
  STAFF
  NURSE
  DOCTOR
}

// ============================================================================
// Youtube Playlist
// ============================================================================

model YoutubePlaylistItem {
  id String @id @default(cuid())

  title     String
  youtubeId String

  durationSec Int?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("youtube_playlist_item")
}

model YoutubeSetting {
  id String @id @default("main")

  muted  Boolean @default(false)
  volume Float   @default(0.5)

  updatedAt DateTime @updatedAt

  @@map("youtube_setting")
}

// ============================================================================
// Carousel Images
// ============================================================================

model CarouselImage {
  id String @id @default(cuid())

  title String?

  fileName String?

  imageUrl String

  cloudinaryId String?

  durationSec Int @default(10)

  sortOrder Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])

  @@map("carousel_image")
}


// ============================================================================
// Footer Messages
// ============================================================================

model FooterMessage {
  id String @id @default(cuid())

  title String?

  message String @db.Text

  isActive Boolean @default(true)

  sortOrder Int @default(0)

  startAt DateTime?
  endAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("footer_message")
}


// ============================================================================
// System Settings
// ตั้งค่าระบบแบบ Dynamic
// ============================================================================

model MediaSetting {
  id String @id @default("main")

  mode        DisplayMode @default(YOUTUBE)
  isCprActive Boolean     @default(false)

  updatedAt DateTime @updatedAt

  @@map("media_setting")
}

// ============================================================================
// Authentication & Authorization
// Better Auth
// ============================================================================

model User {
  id String @id @default(cuid())

  username String @unique
  email String @unique

  displayUsername String?
  name String?

  firstName String @map("first_name")
  lastName String @map("last_name")

  image String?

  role UserRole @default(STAFF)

  banned      Boolean?  @default(false)
  banReason   String?
  banExpires  DateTime?

  isActive        Boolean?  @default(true)
  emailVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  sessions  Session[]
  accounts  Account[]
  auditLogs AuditLog[]

  @@map("user")
}

model Session {
  id String @id

  userId String

  token String

  expiresAt DateTime

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([expiresAt])
  @@index([userId])
  @@map("session")
}

model Account {
  id String @id

  userId String

  providerId String
  accountId  String

  password String?

  accessToken  String?
  refreshToken String?

  idToken String? @db.Text
  scope   String? @db.Text

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

// ============================================================================
// Audit Trail
// เก็บประวัติการกระทำในระบบ
// ============================================================================

model AuditLog {
  id String @id @default(cuid())

  userId String?

  action String

  entity   String?
  entityId String?

  metadata Json?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([entity, entityId])
  @@map("audit_log")
}

// ============================================================================
// Verification
// Email Verification / Password Reset / OTP
// ============================================================================

model Verification {
  id String @id

  identifier String @db.Text
  value      String @db.Text

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier(length: 191)])
  @@map("verification")
}
